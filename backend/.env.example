# =============================================================================
# Exemple de configuration. Copier vers `.env` pour le développement local.
# En production, ces valeurs sont injectées via le gestionnaire de secrets de
# l'orchestrateur (jamais committées, jamais loggées — cf. SECURITY.md).
# =============================================================================

# --- Réseau ---
# Adresse d'écoute. Port NON privilégié : le binaire tourne sans CAP_NET_BIND
# et derrière un reverse proxy assurant la terminaison TLS.
APP_BIND_ADDR=0.0.0.0:8080

# Nombre de proxys de confiance en frontal. Sert à déterminer l'IP cliente
# réelle à partir de X-Forwarded-For sans se faire usurper l'IP.
APP_TRUSTED_PROXY_HOPS=1

# --- Base de données ---
# URL utilisée par l'application au RUNTIME : rôle applicatif aux droits DML
# uniquement (aucun DDL). Les migrations utilisent un rôle distinct (cf. README).
DATABASE_URL=postgres://app_user:app_dev_pw@localhost:5432/websitebase

# URL réservée aux migrations (rôle propriétaire avec droits DDL). Utilisée
# par `sqlx migrate run` et par la CI, jamais par le binaire applicatif.
DATABASE_MIGRATION_URL=postgres://app_owner:owner_dev_pw@localhost:5432/websitebase

# Taille du pool de connexions.
DATABASE_MAX_CONNECTIONS=10

# --- JWT / sessions ---
# Secret de signature des tokens d'accès (HS256). DOIT faire >= 32 octets.
# Générer avec : openssl rand -base64 48
JWT_SECRET=CHANGE_ME_dev_secret_at_least_32_bytes_long_value_please

# Émetteur attendu dans les claims (iss).
JWT_ISSUER=websitebase

# Durée de vie du token d'accès en secondes (court : 15 min recommandé).
JWT_ACCESS_TTL_SECONDS=900

# Durée de vie du refresh token en secondes (révocable, ex. 14 jours).
REFRESH_TTL_SECONDS=1209600

# --- CORS ---
# Liste blanche explicite d'origines autorisées (séparées par des virgules).
# JAMAIS de wildcard avec credentials.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cookies ---
# Mettre à `true` en production (HTTPS). En dev HTTP local, `false` permet
# au navigateur d'accepter le cookie sans TLS.
COOKIE_SECURE=false

# --- Limites & timeouts ---
# Taille maximale du corps de requête en octets (défaut 1 Mo).
MAX_BODY_BYTES=1048576

# Timeout par requête en secondes.
REQUEST_TIMEOUT_SECONDS=15

# --- Sécurité applicative ---
# Verrouillage de compte après N échecs de login.
LOGIN_MAX_FAILED_ATTEMPTS=5
# Durée du verrouillage en secondes.
LOGIN_LOCKOUT_SECONDS=900

# --- Observabilité ---
# Filtre de logs façon RUST_LOG (ex. info, websitebase_backend=debug).
LOG_FILTER=info
