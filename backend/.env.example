# =============================================================================
# Exemple de configuration. Copier vers `.env` pour le développement local.
# En production, ces valeurs sont injectées via le gestionnaire de secrets de
# l'orchestrateur (jamais committées, jamais loggées — cf. SECURITY.md).
# =============================================================================

# --- Réseau ---
# Adresse d'écoute. Port NON privilégié : le binaire tourne sans CAP_NET_BIND
# et derrière un reverse proxy assurant la terminaison TLS.
APP_BIND_ADDR=0.0.0.0:8080

# Nombre de proxys de confiance en frontal. Sert à déterminer l'IP cliente
# réelle à partir de X-Forwarded-For sans se faire usurper l'IP.
APP_TRUSTED_PROXY_HOPS=1

# --- Base de données ---
# URL utilisée par l'application au RUNTIME : rôle applicatif aux droits DML
# uniquement (aucun DDL). Les migrations utilisent un rôle distinct (cf. README).
DATABASE_URL=postgres://app_user:app_dev_pw@localhost:5432/websitebase

# URL réservée aux migrations (rôle propriétaire avec droits DDL). Utilisée
# par `sqlx migrate run` et par la CI, jamais par le binaire applicatif.
DATABASE_MIGRATION_URL=postgres://app_owner:owner_dev_pw@localhost:5432/websitebase

# Taille du pool de connexions.
DATABASE_MAX_CONNECTIONS=10

# --- Sessions (Redis) ---
# Store de sessions = SOURCE DE VÉRITÉ des sessions / refresh tokens (rotation,
# TTL natif, révocation immédiate). OBLIGATOIRE : l'auth en dépend (fail-fast).
# `redis://` en dev ; `rediss://` (TLS) en production. Voir SESSIONS.md.
REDIS_URL=redis://localhost:6379

# Durée de vie ABSOLUE d'une session (plafond dur, non prolongeable ; au-delà,
# nouvelle authentification exigée). Le TTL glissant (idle) réutilise REFRESH_TTL_SECONDS.
SESSION_ABSOLUTE_TTL_SECONDS=2592000

# Rate limiting d'auth DISTRIBUÉ (par IP), complémentaire du rate limiting en
# mémoire (tower_governor). Quota max par fenêtre, et taille de la fenêtre.
AUTH_RATE_LIMIT_MAX=30
AUTH_RATE_LIMIT_WINDOW_SECONDS=60

# --- JWT / sessions ---
# Secret de signature des tokens d'accès (HS256). DOIT faire >= 32 octets.
# Générer avec : openssl rand -base64 48
JWT_SECRET=CHANGE_ME_dev_secret_at_least_32_bytes_long_value_please

# Émetteur attendu dans les claims (iss).
JWT_ISSUER=websitebase

# Durée de vie du token d'accès en secondes (court : 15 min recommandé).
JWT_ACCESS_TTL_SECONDS=900

# Durée de vie du refresh token en secondes (révocable, ex. 14 jours).
REFRESH_TTL_SECONDS=1209600

# --- CORS ---
# Liste blanche explicite d'origines autorisées (séparées par des virgules).
# JAMAIS de wildcard avec credentials.
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# --- Cookies ---
# Mettre à `true` en production (HTTPS). En dev HTTP local, `false` permet
# au navigateur d'accepter le cookie sans TLS.
COOKIE_SECURE=false

# --- Limites & timeouts ---
# Taille maximale du corps de requête en octets (défaut 1 Mo).
MAX_BODY_BYTES=1048576

# Timeout par requête en secondes.
REQUEST_TIMEOUT_SECONDS=15

# --- Sécurité applicative ---
# Verrouillage de compte après N échecs de login.
LOGIN_MAX_FAILED_ATTEMPTS=5
# Durée du verrouillage en secondes.
LOGIN_LOCKOUT_SECONDS=900

# --- Observabilité ---
# Filtre de logs façon RUST_LOG (ex. info, websitebase_backend=debug).
LOG_FILTER=info

# --- Monitoring d'API (OpenSearch) — OPTIONNEL ---
# OPT-IN : si OPENSEARCH_URL est absent, le monitoring est désactivé (aucun
# envoi, zéro surcoût). Les logs d'API (succès/erreurs) sont envoyés à
# OpenSearch et visualisés dans OpenSearch Dashboards. Voir MONITORING.md.
#
# URL du cluster. DOIT être en https:// (TLS obligatoire, refus au démarrage
# sinon). Réseau interne uniquement : le cluster n'est JAMAIS exposé au public.
# OPENSEARCH_URL=https://opensearch:9200
#
# DEV uniquement : autorise une URL http:// (cluster sans TLS sur réseau interne,
# ex. overlay docker-compose.observability.yml). Laisser à false en production.
# OPENSEARCH_ALLOW_INSECURE=false
#
# Authentification backend -> OpenSearch. Deux modes (ApiKey prioritaire) :
#   1) Clé d'API (recommandé) :
# OPENSEARCH_API_KEY=base64_api_key_here
#   2) HTTP Basic :
# OPENSEARCH_USERNAME=admin
# OPENSEARCH_PASSWORD=change_me_strong_password
#
# Certificat CA (PEM) pour un cluster à CA privée / certificat auto-signé.
# OPENSEARCH_CA_CERT_PATH=/etc/opensearch-certs/ca.pem
#
# Identité client (PEM concaténant cert + clé) pour le mTLS (optionnel mais
# recommandé en production : authentification mutuelle backend <-> cluster).
# OPENSEARCH_CLIENT_IDENTITY_PATH=/etc/opensearch-certs/client-identity.pem
#
# Préfixe des index quotidiens de logs ([a-z0-9_-], défaut "api-logs"
# -> api-logs-YYYY.MM.DD).
# OPENSEARCH_INDEX_PREFIX=api-logs
#
# Réglages d'envoi (non bloquant) — valeurs par défaut indiquées.
# OPENSEARCH_TIMEOUT_SECONDS=5          # timeout des appels vers le cluster
# OPENSEARCH_BATCH_SIZE=500             # taille de lot avant _bulk
# OPENSEARCH_FLUSH_INTERVAL_SECONDS=2   # vidange périodique du tampon
# OPENSEARCH_CHANNEL_CAPACITY=10000     # au-delà, events abandonnés (pas de blocage)
