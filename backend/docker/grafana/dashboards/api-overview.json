{
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "schemaVersion": 39,
  "version": 1,
  "title": "WebSiteBase — API overview",
  "uid": "websitebase-api",
  "tags": ["websitebase", "api", "observability"],
  "time": { "from": "now-1h", "to": "now" },
  "timezone": "browser",
  "templating": { "list": [] },
  "panels": [
    {
      "id": 1,
      "title": "Requêtes/s par statut",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "fieldConfig": { "defaults": { "unit": "reqps" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total[5m])) by (status)",
          "legendFormat": "{{status}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Taux d'erreur 5xx",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 0.01 },
              { "color": "red", "value": 0.05 }
            ]
          }
        },
        "overrides": []
      },
      "options": { "colorMode": "value", "graphMode": "area", "reduceOptions": { "calcs": ["lastNotNull"] } },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "sum(rate(http_requests_total{outcome=\"server_error\"}[5m])) / clamp_min(sum(rate(http_requests_total[5m])), 0.0001)"
        }
      ]
    },
    {
      "id": 3,
      "title": "Latence p95 par route",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "unit": "s" }, "overrides": [] },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "histogram_quantile(0.95, sum(rate(http_request_duration_seconds_bucket[5m])) by (le, route))",
          "legendFormat": "{{route}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "Logs d'erreur (OpenSearch)",
      "type": "logs",
      "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 16 },
      "options": { "showTime": true, "sortOrder": "Descending", "wrapLogMessage": true },
      "targets": [
        {
          "refId": "A",
          "datasource": { "type": "grafana-opensearch-datasource", "uid": "opensearch" },
          "query": "outcome:server_error OR level:ERROR",
          "queryType": "lucene",
          "timeField": "@timestamp",
          "metrics": [{ "id": "1", "type": "logs" }]
        }
      ]
    }
  ]
}
