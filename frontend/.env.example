# =============================================================================
# Exemple de configuration. Copier vers `.env` pour le développement local.
# AUCUNE variable NEXT_PUBLIC_* : rien n'est exposé au bundle client, et la
# CI vérifie qu'aucune de ces valeurs ne fuit dans le build
# (scripts/check-bundle-secrets.sh).
# =============================================================================

# URL de base de l'API Axum, SANS slash final. Réseau interne uniquement :
# le navigateur ne parle jamais à l'API directement (pattern BFF).
API_BASE_URL=http://localhost:8080

# Secret de chiffrement du cookie de session (iron-session). >= 32 caractères.
# Générer avec : openssl rand -base64 48
SESSION_SECRET=dev_only_change_me_session_secret_32+chars

# `true` en production (HTTPS) : attribut Secure + préfixe __Host- du cookie.
# `false` UNIQUEMENT pour le développement local en HTTP.
COOKIE_SECURE=false

# Origines publiques autorisées pour les Server Actions (anti-CSRF), requises
# uniquement derrière un reverse proxy qui réécrit l'en-tête Host.
# Liste séparée par des virgules, ex. : app.example.com
APP_ALLOWED_ORIGINS=
