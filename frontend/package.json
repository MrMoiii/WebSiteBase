{
  "name": "websitebase-frontend",
  "version": "0.1.0",
  "private": true,
  "description": "Frontend Next.js sécurisé (pattern BFF) consommant l'API Rust/Axum de WebSiteBase.",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "check:bundle-secrets": "bash scripts/check-bundle-secrets.sh",
    "audit:high": "npm audit --audit-level=high"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.15"
    }
  },
  "dependencies": {
    "iron-session": "8.0.4",
    "next": "16.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "server-only": "0.0.1",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "1.60.0",
    "@tailwindcss/postcss": "4.3.0",
    "@types/node": "25.9.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.9",
    "eslint-plugin-security": "4.0.0",
    "tailwindcss": "4.3.0",
    "typescript": "5.9.3",
    "vitest": "4.1.8"
  }
}
